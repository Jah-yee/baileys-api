{
	"name": "wavvy",
	"description": "Self-hosted WhatsApp API gateway with multiple connections support and built-in dashboard, powered by Baileys",
	"private": true,
	"type": "module",
	"repository": "github:ookamiiixd/baileys-api",
	"author": "Royhan (https://github.com/ookamiiixd)",
	"bugs": {
		"url": "https://github.com/ookamiiixd/baileys-api/issues"
	},
	"homepage": "https://github.com/ookamiiixd/baileys-api",
	"license": "MIT",
	"workspaces": [
		"./apps/*",
		"./packages/*"
	],
	"scripts": {
		"prepare": "effect-language-service patch",
		"dev": "bun --filter '@wavvy/shared' build && bun run --parallel --workspaces dev",
		"build": "bun run --parallel --workspaces build",
		"format": "bun run --parallel --workspaces format",
		"lint": "bun run --parallel --workspaces lint",
		"lint:fix": "bun run --parallel --workspaces lint:fix",
		"typecheck": "bun run --parallel --workspaces typecheck"
	},
	"catalog": {
		"typescript": "^5.9.3",
		"@types/bun": "^1.3.9",
		"@biomejs/biome": "2.3.13",
		"@effect/platform": "^0.94.2",
		"baileys": "7.0.0-rc.9",
		"effect": "^3.19.15"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@effect/language-service": "^0.77.0",
		"typescript": "catalog:"
	}
}
