{
	"$schema": "https://biomejs.dev/schemas/2.3.13/schema.json",
	"root": false,
	"extends": "//",
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"rules": {
			"correctness": {
				"noChildrenProp": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off"
			},
			"a11y": {
				"useSemanticElements": "warn"
			}
		}
	}
}
